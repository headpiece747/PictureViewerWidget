<UserControl x:Class="PictureViewerWidget.PictureViewerWidgetSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:Background="White"
             d:DesignHeight="400" d:DesignWidth="300" Margin="10, 25">
    <StackPanel>

        <!-- ═══ IMAGE ═══ -->
        <Expander Header="Image" IsExpanded="True">
            <StackPanel>
                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Picture Folder" FontSize="10" HorizontalAlignment="Stretch"/>
                    <TextBox x:Name="TxtFolderPath" Grid.Column="1" Margin="0,0,4,0"
                             VerticalContentAlignment="Center" FontSize="10" IsReadOnly="True"/>
                    <Button x:Name="BtnBrowse" Grid.Column="2" Content="Browse..."
                            Padding="8,0" MinWidth="60" FontSize="10"
                            Click="BtnBrowse_Click"/>
                </Grid>
            </StackPanel>
        </Expander>

        <!-- ═══ DESIGN ═══ -->
        <Expander Header="Design" Margin="0,10,0,0">
            <StackPanel>

                <CheckBox x:Name="GlobalThemeCheck" Height="20"
                          VerticalContentAlignment="Center" VerticalAlignment="Center"
                          Margin="2,6,2,2" Content="Use Global Theme" FontSize="10"
                          Click="GlobalThemeCheck_Click"/>

                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Background" FontSize="10" HorizontalAlignment="Stretch"/>
                    <Button x:Name="BgColorSelect" Grid.Column="1"
                            HorizontalAlignment="Stretch" Click="ColorSelect_Click"/>
                </Grid>

                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Overlay Text" FontSize="10" HorizontalAlignment="Stretch"/>
                    <TextBox x:Name="TextOverlay" Grid.Column="1"
                             HorizontalAlignment="Stretch" AcceptsReturn="True"
                             TextWrapping="NoWrap" FontSize="10"
                             TextChanged="TextOverlay_TextChanged"/>
                </Grid>

                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Overlay Font" FontSize="10" HorizontalAlignment="Stretch"/>
                    <Button x:Name="OverlayFontSelect" Grid.Column="1"
                            HorizontalAlignment="Stretch" FontSize="10"
                            Click="OverlayFontSelect_Click"/>
                </Grid>

                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Overlay Color" FontSize="10" HorizontalAlignment="Stretch"/>
                    <Button x:Name="OverlayColorSelect" Grid.Column="1"
                            HorizontalAlignment="Stretch" Click="ColorSelect_Click"/>
                </Grid>

                <!-- Overlay position -->
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Overlay Position" FontSize="10"
                           HorizontalAlignment="Stretch" Grid.ColumnSpan="4"/>
                    <Label Grid.Row="1" Content="Horizontal" FontSize="10" HorizontalAlignment="Stretch"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="OverlayXPos"
                              SelectionChanged="OverlayPos_SelectionChanged">
                        <ComboBoxItem Content="Center"/>
                        <ComboBoxItem Content="Left"/>
                        <ComboBoxItem Content="Right"/>
                    </ComboBox>
                    <Label Grid.Row="1" Grid.Column="2" Content="Vertical" FontSize="10" HorizontalAlignment="Stretch"/>
                    <ComboBox Grid.Row="1" Grid.Column="3" x:Name="OverlayYPos"
                              SelectionChanged="OverlayPos_SelectionChanged">
                        <ComboBoxItem Content="Center"/>
                        <ComboBoxItem Content="Top"/>
                        <ComboBoxItem Content="Bottom"/>
                    </ComboBox>
                </Grid>

            </StackPanel>
        </Expander>

        <!-- ═══ ADVANCED OPTIONS ═══ (no slideshow interval) -->
        <Expander Header="Advanced Options" Margin="0,10,0,0">
            <StackPanel>
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Overlay Offset" FontSize="10"
                           HorizontalAlignment="Stretch" Grid.ColumnSpan="4"/>
                    <Label Grid.Row="1" Content="X:" FontSize="10" HorizontalAlignment="Stretch"/>
                    <hc:NumericUpDown Grid.Row="1" Grid.Column="1" x:Name="OverlayXOffset"
                                     ValueChanged="OverlayOffset_ValueChanged"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="Y:" FontSize="10" HorizontalAlignment="Stretch"/>
                    <hc:NumericUpDown Grid.Row="1" Grid.Column="3" x:Name="OverlayYOffset"
                                     ValueChanged="OverlayOffset_ValueChanged"/>
                </Grid>
            </StackPanel>
        </Expander>

    </StackPanel>
</UserControl>
